# ── WhatsApp Cloud API ────────────────────────────────────────────────
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here

# ── AI ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Database ──────────────────────────────────────────────────────────
# Local SQLite (default):
DATABASE_URL=sqlite:///sanmati.db
# Railway PostgreSQL (replace with your Railway DB URL):
# DATABASE_URL=postgresql://user:password@host:port/dbname

# ── CORS ─────────────────────────────────────────────────────────────
# Local dev: leave as * (allows all origins)
ALLOWED_ORIGINS=*
# Production on Railway: set to your Vercel frontend URL
# ALLOWED_ORIGINS=https://your-app.vercel.app

# ── JWT (if using auth) ───────────────────────────────────────────────
JWT_SECRET_KEY=change-this-in-production-to-a-random-secret
JWT_EXPIRE_MINUTES=1440
